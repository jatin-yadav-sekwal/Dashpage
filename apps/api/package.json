{
    "name": "api",
    "module": "src/index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "bun run --watch src/index.ts",
        "build": "bun build src/index.ts --outdir ./dist --target bun",
        "build:cf": "bun build src/index.ts --outdir ./dist --target bun",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:seed": "bun run src/db/seed-themes.ts",
        "storage:setup": "bun run scripts/setup-avatar-bucket.ts",
        "deploy": "wrangler deploy",
        "deploy:prod": "wrangler deploy --env production",
        "dev:cf": "wrangler dev --local"
    },
    "dependencies": {
        "@hono/zod-validator": "^0.7.6",
        "@supabase/supabase-js": "^2.95.3",
        "drizzle-orm": "^0.45.1",
        "hono": "^4.11.7",
        "postgres": "^3.4.8",
        "razorpay": "^2.9.6",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20260313.1",
        "@types/bun": "latest",
        "dotenv": "^17.2.3",
        "drizzle-kit": "^0.31.8",
        "wrangler": "^3.97.0"
    },
    "peerDependencies": {
        "typescript": "^5"
    }
}
