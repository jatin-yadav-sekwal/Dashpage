{
    "name": "api",
    "version": "2.0.0",
    "main": "dist/index.js",
    "type": "module",
    "private": true,
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "dev": "bun run --watch index.ts",
        "build": "tsc",
        "start": "bun run index.ts",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:seed": "bun run src/db/seed-themes.ts",
        "storage:setup": "bun run scripts/setup-avatar-bucket.ts"
    },
    "dependencies": {
        "@hono/zod-validator": "^0.7.6",
        "@supabase/supabase-js": "^2.95.3",
        "drizzle-orm": "^0.45.1",
        "hono": "^4.11.7",
        "postgres": "^3.4.8",
        "razorpay": "^2.9.6",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "dotenv": "^17.2.3",
        "drizzle-kit": "^0.31.8",
        "typescript": "^5"
    },
    "peerDependencies": {
        "typescript": "^5"
    }
}
